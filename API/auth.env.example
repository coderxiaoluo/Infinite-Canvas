# Infinite Canvas — 认证相关配置（可选）
# 默认 AUTH_MODE=off，不启用登录，行为与改造前一致。

# off       — 不鉴权（默认，单机本地使用）
# required  — 所有 /api/* 需 JWT（内网部署时使用）
# AUTH_MODE=off

# AUTH_MODE=required 时必须配置：
# DATABASE_URL=postgresql+asyncpg://infinite_canvas:infinite_canvas@127.0.0.1:5433/infinite_canvas
# JWT_SECRET=9sK7$pR2!zQ8vB5nG3dF0xL6cT1jY4mU7#wA2hE5rS9kP

# JWT_ACCESS_EXPIRE_MIN=30
# JWT_REFRESH_EXPIRE_DAYS=7
